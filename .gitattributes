# Normalise line endings for all text files on checkout.
* text=auto

# Shell gates must stay LF-normalized on Windows; CRLF makes bash see
# carriage returns in options and blank lines.
*.sh text eol=lf

# Force LF for embedded Markdown content used via include_str! so that
# git autocrlf on Windows does not corrupt the frontmatter delimiters.
examples/wiki/content/*.md text eol=lf
autumn/src/**/*.md text eol=lf

# The saas starter is embedded via include_dir! and compared byte-for-byte against
# its rendered form in examples/saas; force LF on both so Windows autocrlf does not
# introduce line-ending drift (mirrors the eol=lf rules above).
autumn-cli/src/starters/saas/** text eol=lf
examples/saas/** text eol=lf
