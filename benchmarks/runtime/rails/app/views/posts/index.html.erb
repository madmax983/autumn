<!DOCTYPE html>
<html lang="en">
<head><meta charset="utf-8"><title>Posts</title></head>
<body>
<h1>Posts</h1>
<ul>
  <% @posts.each do |post| %>
    <li>
      <%= link_to post.title, post_path(post) %>
      &mdash; <%= post.author %>
      <% unless post.published? %><em>[draft]</em><% end %>
    </li>
  <% end %>
</ul>
</body>
</html>
