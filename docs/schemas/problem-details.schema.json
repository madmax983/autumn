{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autumn.dev/schemas/problem-details.schema.json",
  "title": "Autumn Problem Details",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "type",
    "title",
    "status",
    "detail",
    "instance",
    "code",
    "request_id",
    "errors"
  ],
  "properties": {
    "type": {
      "type": "string",
      "format": "uri-reference"
    },
    "title": {
      "type": "string"
    },
    "status": {
      "type": "integer",
      "minimum": 400,
      "maximum": 599
    },
    "detail": {
      "type": "string"
    },
    "instance": {
      "type": ["string", "null"]
    },
    "code": {
      "type": "string",
      "pattern": "^autumn\\.[a-z0-9_]+$"
    },
    "request_id": {
      "type": ["string", "null"]
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["field", "messages"],
        "properties": {
          "field": {
            "type": "string"
          },
          "messages": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
