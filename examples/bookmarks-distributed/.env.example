# Copy this file to .env and fill in the values.
# .env is gitignored — never commit real secrets.
#
# Generate AUTUMN_SECURITY__SIGNING_SECRET:
#
#   PowerShell:
#     -join ((1..32) | ForEach-Object { '{0:x2}' -f (Get-Random -Max 256) })
#
#   bash / openssl:
#     openssl rand -hex 32
#
# All replicas must share the same value so session cookies and CSRF tokens
# signed by one replica are accepted by the others.

AUTUMN_SECURITY__SIGNING_SECRET=replace-me
