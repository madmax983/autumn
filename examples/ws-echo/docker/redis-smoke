#!/bin/sh
set -eu

out="/tmp/ws-echo-sse.out"
rm -f "$out"

curl -fsS --no-buffer --max-time 20 http://app1:3000/events > "$out" &
sse_pid="$!"

cleanup() {
    kill "$sse_pid" 2>/dev/null || true
}
trap cleanup EXIT INT TERM

sleep 1
curl -fsS -X POST http://app2:3000/notify >/dev/null

i=0
while [ "$i" -lt 20 ]; do
    if grep -q "hx-swap-oob" "$out"; then
        echo "Redis channel fan-out smoke passed"
        exit 0
    fi
    i=$((i + 1))
    sleep 1
done

echo "Redis channel fan-out smoke failed; SSE output was:" >&2
cat "$out" >&2 || true
exit 1
