+    fn detect_platform_supported_combinations() {
+        let cases = [
+            ("linux", "x86_64", "tailwindcss-linux-x64"),
+            ("linux", "aarch64", "tailwindcss-linux-arm64"),
+            ("macos", "x86_64", "tailwindcss-macos-x64"),
